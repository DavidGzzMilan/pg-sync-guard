# Copy to .streamlit/secrets.toml and fill in. Do not commit secrets.toml.

[control_database]
host = "localhost"
port = 5432
database = "your_control_db"
user = "syncguard_user"
password = "your_password"

[subscriber_database]
host = "localhost"
port = 5433
database = "your_subscriber_db"
user = "syncguard_user"
password = "your_password"
